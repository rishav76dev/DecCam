# ─────────────────────────────────────────────────────────────
#  DecCampaign Worker — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# ── ScrapingDog ───────────────────────────────────────────────
# Get your key at https://www.scrapingdog.com/
SCRAPING_DOG_API_KEY=your_api_key_here

# ── Worker HTTP Server ────────────────────────────────────────
PORT=3001

# ── Blockchain (optional — for on-chain finalisation) ─────────
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0x_your_brand_wallet_private_key
CONTRACT_ADDRESS=0x_your_deployed_campaign_contract_address
